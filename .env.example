# Crea una aplicación en https://discord.com/developers/applications
DISCORD_TOKEN=pega_aqui_el_token_del_bot

# Opcional pero recomendado durante el desarrollo. Los comandos aparecen
# inmediatamente en este servidor en lugar de esperar la sincronización global.
DISCORD_GUILD_ID=

# Zona horaria usada cuando /evento crear recibe una fecha sin zona.
BOT_TIMEZONE=America/Bogota

# Ruta de la base de datos local.
DATABASE_PATH=data/albion_guild_bot.db

# INFO, DEBUG, WARNING o ERROR.
LOG_LEVEL=INFO

